@model List<Common.DTO.ProductDTO>
@{
    ViewData["Title"] = "Správa produktov";
}

<h2>Správa produktov</h2>

<p>
    <a href="/Admin/CreateProduct">+ Pridať nový produkt</a> |
    <a href="/Admin/Logout">Odhlásiť sa z Admin</a>
</p>

@if (Model.Any())
{
    <table border="1">
 <tr>
   <th>ID</th>
     <th>Názov</th>
     <th>Kategória</th>
         <th>Cena</th>
     <th>Na sklade</th>
    <th>Akcie</th>
 </tr>
   @foreach (var product in Model)
     {
   <tr>
            <td>@product.Id</td>
     <td>@product.Name</td>
  <td>@product.CategoryName</td>
 <td>@product.Price.ToString("N2") €</td>
  <td>@product.StockAmount ks</td>
        <td>
             <a href="/Admin/EditProduct/@product.Id">Upraviť</a> |
     <form method="post" asp-action="DeleteProduct" asp-route-id="@product.Id" style="display:inline;">
           <button type="submit" onclick="return confirm('Naozaj chcete zmazať tento produkt?')">Zmazať</button>
       </form>
  </td>
     </tr>
        }
 </table>
}
else
{
    <p><em>Žiadne produkty</em></p>
}

<p><a href="/">← Späť na domov</a></p>
