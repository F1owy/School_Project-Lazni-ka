@{
    ViewData["Title"] = "Produkty";
}

<div class="container py-4">
 <h1>Produkty</h1>
    @if (ViewBag.Category != null)
 {
    <p>Kategória: @ViewBag.Category</p>
   }

    <div class="row g-4">
   @for (int i = 1; i <= 8; i++)
        {
    <div class="col-md-6 col-lg-3">
  <div class="card h-100">
   <div class="bg-secondary" style="height: 150px;"></div>
           <div class="card-body">
      <h5 class="card-title">Produkt @i</h5>
       <p class="text-muted">Popis produktu</p>
           <p class="fw-bold text-primary">@(499 + i * 50) €</p>
       <a href="/Products/Details/@Guid.NewGuid()" class="btn btn-outline-primary btn-sm">Detail</a>
             <a href="#" class="btn btn-primary btn-sm">Do košíka</a>
     </div>
    </div>
   </div>
      }
    </div>
</div>
