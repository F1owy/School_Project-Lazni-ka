<!DOCTYPE html>
<html lang="sk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PhotoShop</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
         <a class="navbar-brand fw-bold" href="/"><i class="bi bi-camera"></i> PhotoShop</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
       <span class="navbar-toggler-icon"></span>
  </button>
      <div class="collapse navbar-collapse" id="navbarNav">
           <ul class="navbar-nav me-auto">
     <li class="nav-item"><a class="nav-link" asp-controller="Products" asp-action="Index">Produkty</a></li>
             <li class="nav-item dropdown">
           <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">Kategórie</a>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item" href="/Products?category=1">Fotoaparáty</a></li>
         <li><a class="dropdown-item" href="/Products?category=2">Objektívy</a></li>
           <li><a class="dropdown-item" href="/Products?category=3">Svetlá</a></li>
       <li><a class="dropdown-item" href="/Products?category=4">Príslušenstvo</a></li>
        <li><a class="dropdown-item" href="/Products?category=5">Audio</a></li>
              </ul>
        </li>
       </ul>
       <ul class="navbar-nav">
      <li class="nav-item">
   <a class="nav-link" asp-controller="Cart" asp-action="Index"><i class="bi bi-cart3"></i> Košík</a>
            </li>
  <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Prihlásiť</a></li>
     <li class="nav-item"><a class="nav-link btn btn-outline-light btn-sm ms-2" asp-controller="Account" asp-action="Register">Registrácia</a></li>
         </ul>
   </div>
  </div>
    </nav>

<main>
        @RenderBody()
    </main>

    <footer class="bg-dark text-light py-4 mt-5">
        <div class="container text-center">
            <p class="mb-0">&copy; 2024 PhotoShop - Fotografické vybavenie</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
