@model List<DataLayer.entities.ProductEntity>
@{
    ViewData["Title"] = "Domov";
}

<h2>Vitajte v PhotoShop</h2>
<p>Profesionálne fotografické vybavenie</p>
<p><a href="/Products">Prezrieť všetky produkty</a></p>

<h3>Kategórie</h3>
<ul>
 <li><a href="/Products?category=1">Fotoaparáty</a></li>
    <li><a href="/Products?category=2">Objektívy</a></li>
 <li><a href="/Products?category=3">Svetlá</a></li>
    <li><a href="/Products?category=4">Príslušenstvo</a></li>
    <li><a href="/Products?category=5">Audio</a></li>
</ul>

<h3>Produkty</h3>
@if (Model.Any())
{
    <table border="1">
        <tr>
          <th>Názov</th>
 <th>Kategória</th>
    <th>Cena</th>
     <th>Na sklade</th>
         <th>Akcie</th>
        </tr>
        @foreach (var product in Model)
        {
     <tr>
  <td>@product.Name</td>
           <td>@product.Category</td>
          <td>@product.Price.ToString("N2") €</td>
       <td>@product.StockAmount ks</td>
        <td>
     <a href="/Products/Details/@product.id">Detail</a> |
   <form method="post" asp-controller="Cart" asp-action="AddItem" style="display:inline;">
    <input type="hidden" name="productId" value="@product.id" />
         <input type="hidden" name="quantity" value="1" />
    <button type="submit">Do košíka</button>
   </form>
   </td>
         </tr>
     }
    </table>
}
else
{
    <p><em>Žiadne produkty</em></p>
}
