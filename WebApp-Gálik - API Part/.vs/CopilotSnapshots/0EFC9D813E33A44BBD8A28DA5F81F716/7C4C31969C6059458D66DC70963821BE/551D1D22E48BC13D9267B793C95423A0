@{
    ViewData["Title"] = "Domov";
}

<h2>Vitajte v PhotoShop</h2>
<p>Profesionálne fotografické vybavenie</p>
<p><a href="/Products">Prezrieť produkty</a></p>

<h3>Kategórie</h3>
<ul>
    <li><a href="/Products?category=1">Fotoaparáty</a></li>
    <li><a href="/Products?category=2">Objektívy</a></li>
    <li><a href="/Products?category=3">Svetlá</a></li>
    <li><a href="/Products?category=4">Príslušenstvo</a></li>
  <li><a href="/Products?category=5">Audio</a></li>
</ul>

<h3>Produkty</h3>
<table border="1">
    <tr>
   <th>Názov</th>
<th>Popis</th>
        <th>Cena</th>
        <th>Akcia</th>
    </tr>
 @for (int i = 1; i <= 4; i++)
    {
 <tr>
      <td>Produkt @i</td>
        <td>Popis produktu</td>
   <td>@(999 + i * 100) €</td>
       <td><a href="#">Do košíka</a></td>
        </tr>
    }
</table>
