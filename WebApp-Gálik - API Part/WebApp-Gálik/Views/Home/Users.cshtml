@using DataLayer.entities
@model List<UserEntity>

<table>
    <thead>
        <tr>
            <th>Meno</th>
            <th>Email</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td><a href="@Url.Action("User", "Home", new {userPublicId = user.PublicId})">@user.Name</a></td>
                <td>@user.Email</td>
                <td>
                    <a href="@Url.Action("DeleteUser", "Home", new { userPublicId = user.PublicId })"
                       onclick="return confirm('Naozaj chcete zmazať tohto používateľa?');"
                       class="btn btn-danger btn-sm">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>