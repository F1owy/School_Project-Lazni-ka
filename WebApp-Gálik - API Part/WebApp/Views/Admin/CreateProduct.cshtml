@model Common.DTO.ProductDTO
@{
    ViewData["Title"] = "Pridať produkt";
}

<h2>Pridať nový produkt</h2>

<form method="post" asp-action="CreateProduct">
 <p>
  <label for="Name">Názov produktu:</label><br />
  <input type="text" asp-for="Name" required />
 </p>

    <p>
       <label for="Description">Popis:</label><br />
   <textarea asp-for="Description" rows="4" cols="50"></textarea>
    </p>

 <p>
 <label for="Price">Cena (€):</label><br />
    <input type="number" asp-for="Price" step="0.01" min="0" required />
    </p>

 <p>
      <label for="Category">Kategória:</label><br />
  <select asp-for="Category">
       <option value="1">Fotoaparáty</option>
       <option value="2">Objektívy</option>
          <option value="3">Svetlá</option>
            <option value="4">Príslušenstvo</option>
      <option value="5">Audio</option>
        </select>
    </p>

    <p>
     <label for="StockAmount">Počet na sklade:</label><br />
  <input type="number" asp-for="StockAmount" min="0" required />
    </p>

   <p>
     <button type="submit">Pridať produkt</button>
 </p>
</form>

<p><a href="/Admin/Products">? Späť na zoznam</a></p>
